{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "/usr/bin/say 'works done.'" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/log-webfetch.sh"
          }
        ]
      }
    ]
  }
}
